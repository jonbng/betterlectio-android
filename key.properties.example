# Paths are relative to the android/ project root (this folder).
#
#   cp key.properties.example key.properties
#
# See SIGNING.md for create vs reuse, Play App Signing, and keytool commands.

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=upload
storeFile=upload-keystore.jks
