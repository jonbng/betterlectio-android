<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Cold-start splash (black owl on white). Switches to Theme.BetterLectio after
      installSplashScreen() / first frame. Night uses values-night colors + drawables.
    -->
    <style name="Theme.BetterLectio.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/android12splash</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.BetterLectio</item>
    </style>

    <!-- AppCompat parent required by MainActivity (AppCompatActivity) for per-app locales. -->
    <style name="Theme.BetterLectio" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:colorBackground">@color/splash_background</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
